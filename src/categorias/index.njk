---
layout: layouts/page.njk
title: Categorías
description: Acceso por áreas temáticas del derecho comercial, patrimonial e inmobiliario.
---
<div class="category-list">
  {% for categoria in collections.categorias %}
    <section class="category-block">
      <h2>{{ categoria.nombre }}</h2>
      <div class="article-list">
        {% for post in categoria.articulos %}
          <article>
            <p class="article-meta">{{ post.date | fechaES }}</p>
            <h3><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
            <p>{{ post.data.description }}</p>
          </article>
        {% endfor %}
      </div>
    </section>
  {% endfor %}
</div>
